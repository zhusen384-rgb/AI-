# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=interview_system
PGDATABASE_URL=postgresql://postgres:your_password@localhost:5432/interview_system
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/interview_system

# Legacy Coze Integration (some non-core modules may still depend on it)
COZE_API_KEY=your_coze_api_key
COZE_API_ENDPOINT=https://api.coze.com

# MeloTTS (local sidecar for interview TTS)
MELOTTS_ENABLED=false
MELOTTS_BASE_URL=http://127.0.0.1:5001
MELOTTS_LANGUAGE=ZH
MELOTTS_DEVICE=auto

# Ark / LLM Routing
ARK_API_KEY=your_ark_api_key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MODEL_NAME=doubao-seed-2-0-pro-260215
ARK_INTERVIEW_MODEL=doubao-seed-2-0-pro-260215
ARK_EVALUATION_MODEL=doubao-seed-2-0-pro-260215
ARK_RESUME_MODEL=doubao-seed-2-0-pro-260215
ARK_RESUME_VISION_MODEL=doubao-seed-1-8-251228
ARK_FORCE_SCENE_MODELS=true

# Object Storage (for resume files and recordings)
S3_ENDPOINT=your_s3_endpoint
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET=your_bucket_name
S3_REGION=your_region

# App Configuration
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Doubao Voice Integration (ASR / TTS)
DOUBAO_VOICE_APP_ID=your_app_id
DOUBAO_VOICE_ACCESS_TOKEN=your_access_token
DOUBAO_VOICE_SECRET_KEY=your_secret_key
DOUBAO_ASR_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_nostream
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
DOUBAO_TTS_ENDPOINT=wss://openspeech.bytedance.com/api/v3/tts/bidirection
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0

# Auto Greeting Browser
AUTO_GREETING_HEADLESS=true
AUTO_GREETING_SLOW_MO=50
AUTO_GREETING_DEFAULT_TIMEOUT=30000
AUTO_GREETING_VIEWPORT_WIDTH=1920
AUTO_GREETING_VIEWPORT_HEIGHT=1080
# Optional: reuse an installed Chrome or an already logged-in Chrome profile
AUTO_GREETING_CHROME_EXECUTABLE_PATH=
AUTO_GREETING_CHROME_USER_DATA_DIR=
AUTO_GREETING_CHROME_PROFILE_DIR=
# Optional: connect to an existing Chrome started with --remote-debugging-port
AUTO_GREETING_CHROME_WS_ENDPOINT=
AUTO_GREETING_CHROME_BROWSER_URL=

# Authentication
JWT_SECRET=replace_with_a_secure_jwt_secret
REFRESH_TOKEN_SECRET=replace_with_a_separate_refresh_token_secret

# Protected production initialization
INIT_API_TOKEN=replace_with_a_one_time_production_init_token

# Protected migration helpers
MIGRATION_API_KEY=replace_with_a_secure_migration_token
